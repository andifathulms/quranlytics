# Copy to `.env` on the VM and fill in. Used by docker-compose.prod.yml.

# ─── Images (GHCR) ──────────────────────────────────────
IMAGE_OWNER=andifathulms          # your GitHub owner, lowercase
TAG=latest                         # or pin a commit SHA for a known-good build

# ─── Django ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=                        # generate: python -c "import secrets;print(secrets.token_urlsafe(64))"
DEBUG=False
ALLOWED_HOSTS=quranlytics.example,www.quranlytics.example
CORS_ALLOWED_ORIGINS=https://quranlytics.example

# ─── Database (the db service below) ────────────────────
POSTGRES_DB=quranlytics
POSTGRES_USER=quran
POSTGRES_PASSWORD=                 # strong password
DATABASE_URL=postgres://quran:CHANGE_ME@db:5432/quranlytics

# ─── Cache / Queue (the redis service) ──────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── Frontend server-side fetches (compose network) ─────
# The browser uses the build-time NEXT_PUBLIC_API_BASE; SSR uses this.
API_BASE_INTERNAL=http://backend:8000/api/v1

# ─── Optional ───────────────────────────────────────────
QURAN_API_BASE=https://api.quran.com/api/v4
ADMIN_EMAIL=ops@quranlytics.example
# SENTRY_DSN=
